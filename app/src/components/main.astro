---
// ▼ コンポーネントスクリプト（ビルド時に実行）
//   ページ全体の骨格をここで組み立てる。細かいパーツは components/ に分離済み。
//   DESIGN.md の世界観を「グレー2トーン」で抽出したプロトタイプ。
//   レトロPC(WebGL)部分は実装せず、背景は public/mainBackground.png を使用。
import Nav from './Nav.astro';
import Hero from './Hero.astro';
import Section from './Section.astro';
import ProjectCard from './ProjectCard.astro';
import SkillTag from './SkillTag.astro';
import Footer from './Footer.astro';

const name = 'HIJOUSHOKU';
const title = 'PORTFOLIO';

const projects = [
	{
		title: '自宅サーバー構築',
		description: 'Proxmox VEを利用し、自宅に24時間起動するサーバーを構築',
		tags: ['Docker','Ubuntu'],
		overview: 'Proxmox VEを使ってUbuntuのゲームサーバーと複数のwebサービスをホストしています。webサーバーはcloudflare tunnelを利用してポート開放を行わず外部公開しており、リバースプロキシを使ってルーティングを行っています。またtailscaleを利用したVPNサーバーにより、安全なSSH接続で操作をしています。',
		mechanism: 'どんな仕組みで動いているかをここに書く。',
		images: ['home-server.png'] as string[], // 例: ['/works/alpha-1.png', '/works/alpha-2.png']
	},
	{
		title: 'Project Beta',
		description: 'プロジェクトの概要をここに書く。担当範囲や工夫した点など。',
		tags: ['React', 'CSS'],
		overview: '何を作ったかをここに書く。',
		mechanism: 'どんな仕組みで動いているかをここに書く。',
		images: [] as string[],
	},
	{
		title: 'Project Gamma',
		description: 'プロジェクトの概要をここに書く。リンク先で詳細を見せる想定。',
		tags: ['Node', 'API'],
		overview: '何を作ったかをここに書く。',
		mechanism: 'どんな仕組みで動いているかをここに書く。',
		images: [] as string[],
	},
];

const skills = [
	'HTML', 'CSS', 'JavaScript', 'TypeScript', 'React',
	'Astro', 'Node.js', 'Git', 'Figma',
];
---

<Nav />

<main>
	<Hero name={name} title={title} />

	<div class="content">
		<Section id="about" heading="About">
			<p>
				こんにちは。非常食と呼ばれている大学生です。本名は怖いので書きません。技術が大好きで、未熟者ですがサーバーやWEB周りの技術を中心に学んでいます。
				趣味は自作キーボード、ゲーム、古着などです。上は初めて作成したキーボードです。
			</p>
		</Section>

		<Section id="works" heading="Works">
			<div class="works__grid">
				{projects.map((p, i) => (
					<ProjectCard
						id={`work-${i}`}
						title={p.title}
						description={p.description}
						tags={p.tags}
						overview={p.overview}
						mechanism={p.mechanism}
						images={p.images}
					/>
				))}
			</div>
		</Section>

		<Section id="skills" heading="Skills">
			<div class="skills__list">
				{skills.map((s) => <SkillTag label={s} />)}
			</div>
		</Section>

		<Section id="contact" heading="Contact">
			<p>連絡先や各種リンクをここに置く。</p>
			<p>
				<a class="link" href="mailto:you@example.com">you@example.com</a>
			</p>
		</Section>
	</div>

	<Footer />
</main>

<!-- ▼ グローバルスタイル：CSS変数・背景画像・共通ユーティリティ -->
<style is:global>
	:root {
		/* メインカラー＝グレー2トーン（純白/純黒を避ける） */
		--color: #525252; /* 前景・テキスト・枠線（ダークグレー） */
		--paper: #e6e6e6; /* カード/ラベルの地（ライトグレー、旧ベージュの代わり） */
		--edge: #cfcfcf; /* 1pxの薄い縁取り */

		/* DESIGN.md 第4章の二重シャドウ（グレー版） */
		--shadow-2: 1px 1px 0 var(--edge), 6px 6px 0 rgba(82, 82, 82, 0.25);
		--shadow-2-hover: 1px 1px 0 var(--edge), 8px 8px 0 rgba(82, 82, 82, 0.25);
		--shadow-2-active: 1px 1px 0 var(--edge), 3px 3px 0 rgba(82, 82, 82, 0.25);

		--font-pixel: 'MinecraftiaRegular', 'DotGothic16', 'Courier New', monospace;
		--font-body: 'Zen Kaku Gothic New', system-ui, sans-serif;
	}

	* {
		box-sizing: border-box;
	}

	body {
		margin: 0;
		color: var(--color);
		font-family: var(--font-body);
		background-color: #b8b8b8; /* 画像読込前/余白のフォールバック（グレー） */
	}

	/* 背景画像レイヤー：最背面に固定（旧 background-attachment: fixed 相当） */
	body::before {
		content: '';
		position: fixed;
		inset: 0;
		z-index: -2;
		background: url('/mainBackground.png') center / cover no-repeat;
	}

	/* ベールレイヤー：mainBackground.png の上に paper.png を重ねる。
	   opacity は JS がスクロール量から算出して --veil に設定する。
	   スクロール最上部(0)では透明＝mainBackground.png が見え、
	   Works セクションに到達した時点でほぼ paper.png 一色（0.97）になる。 */
	body::after {
		content: '';
		position: fixed;
		inset: 0;
		z-index: -1;
		background: url('/paper.png') center / cover no-repeat;
		opacity: var(--veil, 0);
		pointer-events: none;
	}

	/* ラベルタグ風の見出し：背景色を塗ってネガ表示（DESIGN.md 第3章） */
	.label {
		display: inline-block;
		font-family: var(--font-pixel);
		color: var(--paper);
		background: var(--color);
		padding: 0.4rem 0.7rem;
		margin: 0;
		line-height: 1.2;
		box-shadow: var(--shadow-2);
	}

	/* 本文リンクのホバー（持ち上がる挙動） */
	.link {
		font-family: var(--font-body);
		color: var(--color);
		background: var(--paper);
		text-decoration: none;
		padding: 0.15rem 0.4rem;
		box-shadow: var(--shadow-2);
		transition: transform 0.3s, box-shadow 0.3s;
		display: inline-block;
	}
	.link:hover {
		transform: scale(1.1);
		box-shadow: var(--shadow-2-hover);
	}
</style>

<!-- ▼ このコンポーネント固有のスタイル（スコープ付き） -->
<style>
	/* 本文セクション。背景は body::after（paper.png のベール層）が
	   スクロール量に応じて現れるため、ここは透明にしておく。 */
	.content {
		border-top: 2px dashed var(--color);
		border-bottom: 2px dashed var(--color);
	}

	.works__grid {
		display: grid;
		gap: 1.2rem;
	}

	.skills__list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
	}
</style>

<!-- ▼ ベール（背景の白み）をスクロール量から制御。
     Works セクションに到達した時点で opacity が最大（ほぼグレー一色）になる。 -->
<script>
	const MAX = 0.97; // 最大の白さ（1で完全にグレー一色）

	function update() {
		const works = document.querySelector<HTMLElement>('#works');
		if (!works) return;
		// Works の開始位置までスクロールしたら MAX に到達させる
		const target = works.offsetTop;
		const p = target > 0 ? Math.min(window.scrollY / target, 1) : 1;
		document.documentElement.style.setProperty('--veil', String(p * MAX));
	}

	addEventListener('scroll', update, { passive: true });
	addEventListener('resize', update);
	update();
</script>
