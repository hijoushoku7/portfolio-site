---
// ▼ スキルブロック（レベルバー型）
//   絵文字アイコン + ラベル + 習熟度(level 1〜5)のセグメントバー。
//   既存のグレー2トーン / 破線枠 / 二重シャドウ / ピクセルフォントに沿う。
//   バーの描画は LevelBar に集約（Skills 凡例と共用）。
import LevelBar from './LevelBar.astro';
interface Props {
	icon: string;
	label: string;
	level?: number; // 1〜5
}
const { icon, label, level = 3 } = Astro.props;
---

<div class="sb">
	<span class="sb__head">
		<span class="sb__icon" aria-hidden="true">{icon}</span>
		<span class="sb__label">{label}</span>
	</span>
	<LevelBar level={level} />
</div>

<style>
	.sb {
		display: grid;
		gap: 0.5rem;
		padding: 0.7rem 0.8rem;
		font-family: var(--font-pixel);
		color: var(--color);
		background: var(--paper);
		border: 1px dashed var(--color);
		border-left: 4px solid var(--color);
		box-shadow: var(--shadow-2);
		transition: transform 0.3s, box-shadow 0.3s;
	}
	.sb:hover {
		transform: translateY(-2px);
		box-shadow: var(--shadow-2-hover);
	}

	.sb__head {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}
	.sb__icon {
		font-size: 1.2rem;
		line-height: 1;
	}
	.sb__label {
		font-size: 0.72rem;
		letter-spacing: 0.02em;
	}
</style>
