---
// ▼ プロジェクト詳細モーダル
//   ProjectCard からビルド時に props を受け取り、非表示(hidden)で待機。
//   カードのクリックで JS が hidden を外して表示する。
//   閉じる：右上の×ボタン / 背景クリック / Escキー（いずれも JS）。
//   中身：写真（複数枚）→ 作ったもの → 仕組み → 使用技術。
const {
	id,
	title,
	overview = '',
	mechanism = '',
	tags = [],
	images = [],
} = Astro.props;
---

<div class="modal" id={id} hidden>
	<div class="modal__card" role="dialog" aria-modal="true" aria-label={title}>
		<button class="modal__close" type="button" data-modal-close aria-label="閉じる">×</button>

		{images.length > 0 ? (
			<div class="modal__gallery">
				{images.map((src: string) => (
					<img class="modal__img" src={src} alt={title} loading="lazy" />
				))}
			</div>
		) : (
			<div class="modal__gallery modal__gallery--empty">
				<span class="modal__placeholder">IMAGE</span>
			</div>
		)}

		<h3 class="modal__title">{title}</h3>

		{overview && (
			<section class="modal__section">
				<h4 class="modal__heading">作ったもの</h4>
				<p class="modal__text">{overview}</p>
			</section>
		)}

		{mechanism && (
			<section class="modal__section">
				<h4 class="modal__heading">仕組み</h4>
				<p class="modal__text">{mechanism}</p>
			</section>
		)}

		{tags.length > 0 && (
			<section class="modal__section">
				<h4 class="modal__heading">使用技術</h4>
				<ul class="modal__tech">
					{tags.map((t: string) => <li>{t}</li>)}
				</ul>
			</section>
		)}
	</div>
</div>

<style>
	/* 背景（暗幕）。クリックで閉じる */
	.modal {
		position: fixed;
		inset: 0;
		z-index: 50;
		display: flex;
		align-items: flex-start;
		justify-content: center;
		padding: 2rem 1rem;
		overflow-y: auto;
		background: rgba(82, 82, 82, 0.6);
	}

	/* hidden属性で非表示にする。.modal の display:flex を上書きするため、
	   属性セレクタと併用して優先度を上げる（標準の [hidden]{display:none} は負けるため）。 */
	.modal[hidden] {
		display: none;
	}

	/* 本体カード */
	.modal__card {
		position: relative;
		width: 100%;
		max-width: 560px;
		margin: auto;
		padding: 1.6rem;
		background: var(--paper);
		box-shadow: var(--shadow-2);
	}

	.modal__close {
		position: absolute;
		top: 0.8rem;
		right: 0.8rem;
		width: 34px;
		height: 34px;
		font-family: var(--font-pixel);
		font-size: 1.1rem;
		line-height: 1;
		color: var(--paper);
		background: var(--color);
		border: none;
		cursor: pointer;
		box-shadow: 1px 1px 0 var(--edge);
		transition: transform 0.3s;
	}
	.modal__close:hover {
		transform: scale(1.1);
	}

	.modal__gallery {
		display: grid;
		gap: 0.8rem;
		margin-bottom: 1.2rem;
	}
	.modal__img {
		width: 100%;
		height: auto;
		display: block;
		border: 1px solid var(--edge);
	}

	/* 写真未設定時のプレースホルダ */
	.modal__gallery--empty {
		aspect-ratio: 16 / 9;
		place-items: center;
		border: 2px dashed var(--color);
	}
	.modal__placeholder {
		font-family: var(--font-pixel);
		font-size: 0.7rem;
		opacity: 0.5;
	}

	.modal__title {
		font-family: var(--font-pixel);
		font-size: 1.1rem;
		margin: 0 0 1rem;
	}

	.modal__section {
		margin-bottom: 1.1rem;
	}

	.modal__heading {
		font-family: var(--font-pixel);
		font-size: 0.8rem;
		margin: 0 0 0.4rem;
		padding-bottom: 0.3rem;
		border-bottom: 1px dashed var(--color);
	}

	.modal__text {
		font-family: var(--font-body);
		font-size: 0.9rem;
		line-height: 1.7;
		margin: 0;
	}

	.modal__tech {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.modal__tech li {
		font-family: var(--font-pixel);
		font-size: 0.6rem;
		padding: 0.25rem 0.4rem;
		border: 1px dashed var(--color);
	}
</style>

<!-- ▼ 閉じる制御（×ボタン / 背景クリック / Esc）。イベント委譲で全モーダル共通。 -->
<script>
	function closeModal(modal: HTMLElement) {
		modal.hidden = true;
		document.body.style.overflow = '';
	}

	document.addEventListener('click', (e) => {
		const target = e.target as HTMLElement;
		// ×ボタン
		if (target.closest('[data-modal-close]')) {
			const modal = target.closest<HTMLElement>('.modal');
			if (modal) closeModal(modal);
			return;
		}
		// 背景（暗幕）そのものをクリック
		if (target.classList.contains('modal')) {
			closeModal(target);
		}
	});

	document.addEventListener('keydown', (e) => {
		if (e.key !== 'Escape') return;
		document
			.querySelectorAll<HTMLElement>('.modal:not([hidden])')
			.forEach((modal) => closeModal(modal));
	});
</script>
