---
// ▼ Zine風セクションの共通ラッパー
//   見出しは「ラベルタグ」表示、セクション下端は破線で区切る（DESIGN.md 第5章）。
//   中身は <slot /> で受け取り、呼び出し側が自由に組める。
const { id, heading } = Astro.props;
---

<section id={id} class="section">
	<h2 class="label section__heading">{heading}</h2>
	<div class="section__body">
		<slot />
	</div>
</section>

<style>
	.section {
		width: clamp(0px, 95vw, 680px);
		margin: 0 auto;
		padding: 3rem 0;
		border-bottom: 2px dashed var(--color);
	}

	.section__heading {
		font-size: clamp(1.1rem, 4vw, 1.6rem);
		margin: 0 0 1.5rem;
	}

	.section__body {
		font-family: var(--font-body);
		color: var(--color);
		line-height: 1.8;
	}
</style>
