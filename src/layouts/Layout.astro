---
import Loader from '../components/Loader.astro';
import Curtain from '../components/Curtain.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/works/icon.png" />
		<link rel="icon" href="/works/icon.png" />
		<meta name="generator" content={Astro.generator} />
		<meta name="theme-color" content="#525252" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<!-- Minecraftia: 自前ホスト + preload でローダー表示時に確実に適用 -->
		<link
			rel="preload"
			href="/fonts/MinecraftiaRegular.ttf"
			as="font"
			type="font/ttf"
			crossorigin
		/>
		<style is:inline>
			@font-face {
				font-family: 'Minecraftia';
				src: url('/fonts/MinecraftiaRegular.ttf') format('truetype');
				font-weight: normal;
				font-style: normal;
				font-display: block;
			}
		</style>
		<link
			href="https://fonts.googleapis.com/css2?family=DotGothic16&family=Zen+Kaku+Gothic+New:wght@400;500;700&display=swap"
			rel="stylesheet"
		/>
		<title>Hijoushokuのホームページ</title>
	</head>
	<body>
		<Loader />
		<Curtain />
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
