		font-size: 0.75rem;
		letter-spacing: 0.08em;
		color: var(--paper);
		background: var(--color);
		display: inline-block;
		padding: 0.2rem 0.5rem;
		margin: 0 0 0.8rem;
	}

	.skills__grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
		gap: 0.7rem;
	}
</style>

<!-- ▼ ベール（背景の白み）をスクロール量から制御。
     Works セクションに到達した時点で opacity が最大（ほぼグレー一色）になる。 -->
<script>
	const MAX = 0.97; // 最大の白さ（1で完全にグレー一色）

	function update() {
		const about = document.querySelector<HTMLElement>('#about');
		if (!about) return;
		// About の開始位置までスクロールしたら MAX に到達させる
		const target = about.offsetTop;
		const p = target > 0 ? Math.min(window.scrollY / target, 1) : 1;
		document.documentElement.style.setProperty('--veil', String(p * MAX));
	}

	addEventListener('scroll', update, { passive: true });
	addEventListener('resize', update);
	update();
</script>
