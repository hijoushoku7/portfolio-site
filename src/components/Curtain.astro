<div class="container" id="curtain">
    <div class="curtain">
    <div class="curtain__left"></div>
    <div class="curtain__right"></div>
    </div>
</div>


<style>
    .container {
    position: fixed;
    top: 50%;
    left: 50%;
    width: 100%;
    aspect-ratio: 1;
    /* 背景は透明。幕が開いたら本編（背景写真）がそのまま見える */
    background-color: transparent;
    transform: translate(-50%, -50%);
    overflow: hidden;
    /* ローダー(9999)より前面に。ローダーのフェードアウトと幕の開始を重ねる */
    z-index: 10000;
    /* ローダー完了の合図(.is-active)が来るまでは待機（非表示） */
    display: none;
    }
    .container.is-active {
    display: block;
    }

    .curtain {
    position: absolute;
    inset: 0;
    }

    .curtain__left,
    .curtain__right {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 150%;

    &::before {
        content: "";
        display: block;
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: currentColor;
    }
    }
    /* アニメの開始は .is-active が付いてから（＝ローダー完了後） */
    .is-active .curtain__left::before,
    .is-active .curtain__right::before {
    animation:
        close 0.5s ease-in-out var(--close-delay, 0s) both,
        open 0.5s ease-in-out var(--open-delay, 0s) forwards;
    }
    .curtain__left {
    --close-delay: 0.1s;
    --open-delay: 0.75s;
    color: #bbb;
    }
    .curtain__right {
    --close-delay: 0.2s;
    --open-delay: 0.75s;
    color: #999;
    transform: scaleX(-1);
    }
    @keyframes close {
    from,
    to {
        transform-origin: left top;
    }

    from {
        box-shadow: -10px -10px 16px rgba(0, 0, 0, 0);
    }
    50%,
    to {
        box-shadow: -60px -15px 16px rgba(0, 0, 0, 0.1);
    }

    from {
        transform: translateX(101%) rotate(-25deg);
    }
    to {
        transform: translateX(0%) rotate(0deg);
    }
    }
    @keyframes open {
    from,
    to {
        transform-origin: right top;
    }

    from,
    50% {
        box-shadow: -60px -15px 16px rgba(0, 0, 0, 0.1);
    }
    to {
        box-shadow: -10px -10px 16px rgba(0, 0, 0, 0);
    }

    from {
        transform: translateX(0%) rotate(0deg);
    }
    to {
        transform: translateX(-101%) rotate(25deg);
    }
    }
</style>

<script>
	// ローダー完了の合図('loader:done')を受けて幕アニメを開始し、
	// 開き終わったら幕を撤去して本編を見せる。
	const curtain = document.getElementById('curtain');
	if (curtain) {
		// 合図が来たら .is-active を付与してアニメ開始
		window.addEventListener('loader:done', () => curtain.classList.add('is-active'), {
			once: true,
		});

		// open アニメの完了で幕を撤去（left/right どちらか先に発火した時点でOK）
		curtain.addEventListener('animationend', (e) => {
			if ((e as AnimationEvent).animationName === 'open') curtain.remove();
		});
	}
</script>

