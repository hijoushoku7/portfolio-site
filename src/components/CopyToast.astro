<div id="copy-toast" class="copy-toast">Copied!</div>

<style>
	.copy-toast {
		position: fixed;
		bottom: 2.5rem;
		left: 50%;
		transform: translateX(-50%) scale(0);
		background: var(--color);
		color: var(--paper);
		font-family: var(--font-pixel);
		font-size: 0.8rem;
		padding: 0.5rem 1.2rem;
		box-shadow: var(--shadow-2);
		opacity: 0;
		pointer-events: none;
		z-index: 100;
	}

	.copy-toast.show {
		animation: toast-pop 1.8s ease forwards;
	}

	@keyframes toast-pop {
		0%   { transform: translateX(-50%) scale(0);    opacity: 0; }
		15%  { transform: translateX(-50%) scale(1.15); opacity: 1; }
		25%  { transform: translateX(-50%) scale(0.92); opacity: 1; }
		35%  { transform: translateX(-50%) scale(1);    opacity: 1; }
		65%  { transform: translateX(-50%) scale(1);    opacity: 1; }
		100% { transform: translateX(-50%) scale(1);    opacity: 0; }
	}
</style>

<script>
	const toast = document.getElementById('copy-toast');

	window.addEventListener('copy-toast', () => {
		if (!toast) return;
		toast.classList.remove('show');
		void toast.offsetWidth;
		toast.classList.add('show');
	});
</script>
