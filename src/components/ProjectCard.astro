---
// ▼ 制作物カード
//   画像 + タイトル + 説明。全体に統一の二重シャドウを付け、
//   「コラージュに貼り付けたプリント」感を出す（DESIGN.md 第4・5章）。
//   クリックすると、同じ props を渡してビルド時にレンダリングしておいた
//   Modal を JS で表示する（data-modal-open → Modal の id を指す）。
import Modal from './Modal.astro';

const {
	id,
	title,
	description,
	tags = [],
	overview = '',
	mechanism = '',
	images = [],
} = Astro.props;
---

<button class="card" type="button" data-modal-open={id}>
	<div class="card__thumb">
		{images.length > 0 ? (
			<img class="card__thumb-img" src={images[0]} alt={title} loading="lazy" />
		) : (
			<span class="card__placeholder">IMAGE</span>
		)}
	</div>
	<div class="card__body">
		<h3 class="card__title">{title}</h3>
		<p class="card__desc">{description}</p>
		{tags.length > 0 && (
			<ul class="card__tags">
				{tags.map((t: string) => <li>{t}</li>)}
			</ul>
		)}
	</div>
</button>

<Modal
	id={id}
	title={title}
	tags={tags}
	overview={overview}
	mechanism={mechanism}
	images={images}
/>

<style>
	.card {
		display: grid;
		grid-template-columns: 120px 1fr;
		gap: 1rem;
		padding: 0.8rem;
		background: var(--paper);
		text-align: left;
		text-decoration: none;
		color: var(--color);
		border: none;
		width: 100%;
		font: inherit;
		cursor: pointer;
		box-shadow: var(--shadow-2);
		transition: transform 0.3s, box-shadow 0.3s;
	}

	.card:hover {
		transform: scale(1.02);
		box-shadow: var(--shadow-2-hover);
	}
	.card:active {
		transform: scale(0.98);
		box-shadow: var(--shadow-2-active);
	}

	.card__thumb {
		aspect-ratio: 1;
		display: grid;
		place-items: center;
		border: 2px dashed var(--color);
	}

	.card__placeholder {
		font-family: var(--font-pixel);
		font-size: 0.7rem;
		opacity: 0.5;
	}

	/* サムネイル写真：枠いっぱいに切り抜いて表示 */
	.card__thumb-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.card__body {
		min-width: 0;
	}

	.card__title {
		font-family: var(--font-pixel);
		font-size: 0.95rem;
		margin: 0 0 0.5rem;
		overflow-wrap: break-word;
	}

	.card__desc {
		font-family: var(--font-body);
		font-size: 0.9rem;
		line-height: 1.7;
		margin: 0 0 0.7rem;
		overflow-wrap: break-word;
	}

	.card__tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.card__tags li {
		font-family: var(--font-pixel);
		font-size: 0.6rem;
		padding: 0.25rem 0.4rem;
		border: 1px dashed var(--color);
		overflow-wrap: break-word;
		word-break: break-all;
	}

	@media (max-width: 480px) {
		.card {
			grid-template-columns: 1fr;
		}
	}
</style>

<!-- ▼ カードのクリックで対応するモーダル（#id）を開く。
     Astro が同一スクリプトを1つに束ねるため、イベント委譲で全カードを処理。 -->
<script>
	document.addEventListener('click', (e) => {
		const trigger = (e.target as HTMLElement).closest<HTMLElement>('[data-modal-open]');
		if (!trigger) return;
		const id = trigger.dataset.modalOpen;
		if (!id) return;
		const modal = document.getElementById(id);
		if (!modal) return;
		modal.hidden = false;
		document.body.style.overflow = 'hidden';
	});
</script>
