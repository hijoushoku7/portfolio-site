---
// ▼ ナビゲーション
//   通常時は右上に浮かぶアイコンボタン群 + ハンバーガー。
//   ハンバーガーを押すと左から全画面オーバーレイメニューがスライドイン。
//   （DESIGN.md 第6章を、グレー2トーンで再現）
const links = [
	{ label: 'About', href: '#about' },
	{ label: 'Affiliation', href: '#affiliation' },
	{ label: 'Works', href: '#works' },
	{ label: 'Activities', href: '#activities' },
	{ label: 'Qualifications', href: '#qualifications' },
	{ label: 'Skills', href: '#skills' },
	{ label: 'Contact', href: '#contact' },
];

const socials = [
	{ label: 'GitHub', href: 'https://github.com/hijoushoku7', external: true },
	{ label: 'Mail', href: 'mailto:hijoushoku88@gmail.com', external: false },
];
---

<!-- チェックボックスでメニュー開閉（JSなしのトグル） -->
<input type="checkbox" id="nav-toggle" class="nav-toggle" hidden />

<header class="nav">
	<label class="btn nav__burger" for="nav-toggle" aria-label="メニュー">
		<span></span><span></span><span></span>
	</label>
	<div class="nav__socials">
		{socials.map((s) => (
			<a
				class="btn"
				href={s.href}
				target={s.external ? '_blank' : undefined}
				rel={s.external ? 'noopener noreferrer' : undefined}
			>{s.label}</a>
		))}
	</div>

</header>

<nav class="overlay">
	<label class="btn overlay__close" for="nav-toggle" aria-label="閉じる">×</label>
	<ul class="overlay__list">
		{links.map((link) => (
			<li><a href={link.href}>{link.label}</a></li>
		))}
	</ul>
</nav>

<script>
	const toggle = document.querySelector<HTMLInputElement>('#nav-toggle');
	const linkList = document.querySelector('.overlay__list');

	linkList?.addEventListener('click', (event) => {
		if (!(event.target instanceof Element)) return;
		if (!event.target.closest('a')) return;

		if (toggle) toggle.checked = false;
	});
</script>

<style>
	.nav {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 20;
		display: flex;
		justify-content: flex-start;
		align-items: center;
		gap: 0.6rem;
		padding: 1rem;
	}

	.nav__socials {
		display: flex;
		gap: 0.6rem;
	}

	.btn {
		font-family: var(--font-pixel);
		font-size: 0.7rem;
		color: var(--paper);
		background: var(--color);
		border: none;
		padding: 0.55rem 0.7rem;
		cursor: pointer;
		text-decoration: none;
		box-shadow: var(--shadow-2);
		transition: transform 0.3s, box-shadow 0.3s;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		line-height: 1;
	}

	.btn:hover {
		transform: scale(1.1);
		box-shadow: var(--shadow-2-hover);
	}

	.btn:active {
		transform: scale(0.95);
		box-shadow: var(--shadow-2-active);
	}

	/* ハンバーガー */
	.nav__burger {
		flex-direction: column;
		gap: 4px;
		width: 38px;
		height: 38px;
	}
	.nav__burger span {
		display: block;
		width: 18px;
		height: 2px;
		background: var(--paper);
	}

	/* 全画面オーバーレイメニュー */
	.overlay {
		position: fixed;
		inset: 0;
		z-index: 30;
		background: var(--color);
		transform: translateX(-100%);
		transition: transform 0.3s ease;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.overlay__close {
		position: absolute;
		top: 1rem;
		right: 1rem;
		font-size: 1.2rem;
		width: 38px;
		height: 38px;
		background: var(--paper);
		color: var(--color);
		box-shadow: 1px 1px 0 var(--color);
	}

	.overlay__list {
		list-style: none;
		margin: 0;
		padding: 0;
		text-align: center;
		display: grid;
		gap: 1.4rem;
	}

	.overlay__list a {
		font-family: var(--font-pixel);
		font-size: clamp(1.6rem, 7vw, 3rem);
		color: var(--paper);
		text-decoration: none;
		transition: transform 0.3s;
		display: inline-block;
	}
	.overlay__list a:hover {
		transform: scale(1.1);
	}

	/* トグル制御 */
	:global(#nav-toggle:checked) ~ .overlay {
		transform: translateX(0);
	}
</style>
